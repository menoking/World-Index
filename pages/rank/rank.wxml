<view class="page rank-page {{themeClass}}">
  <view class="rank-header">
    <view>
      <view class="section-title">热度指数</view>
      <view class="rank-scope">{{scopeText}}</view>
    </view>
    <view class="rank-actions">
      <button class="theme-toggle" bindtap="toggleTheme">{{themeText}}</button>
      <button class="clear-button" wx:if="{{currentSector}}" bindtap="clearSector">全市场</button>
    </view>
  </view>

  <view class="filter-bar">
    <view class="tabs">
      <view
        class="{{period === 'daily' ? 'tab active' : 'tab'}}"
        data-period="daily"
        bindtap="switchPeriod"
      >每日</view>
      <view
        class="{{period === 'weekly' ? 'tab active' : 'tab'}}"
        data-period="weekly"
        bindtap="switchPeriod"
      >每周</view>
      <view
        class="{{period === 'monthly' ? 'tab active' : 'tab'}}"
        data-period="monthly"
        bindtap="switchPeriod"
      >每月</view>
      <view
        class="{{period === 'all' ? 'tab active' : 'tab'}}"
        data-period="all"
        bindtap="switchPeriod"
      >成立</view>
    </view>
    <view class="purchasable-toggle {{purchasable ? 'active' : ''}}" bindtap="togglePurchasable">
      {{purchasable ? '可申购' : '全部'}}
    </view>
  </view>

  <scroll-view class="rank-list" scroll-y="true">
    <view class="rank-item" wx:for="{{funds}}" wx:key="code" data-code="{{item.code}}" bindtap="openFund">
      <view class="{{index < 3 ? 'rank-number top' : 'rank-number'}}">{{index + 1}}</view>
      <view class="fund-info">
        <view class="fund-name">{{item.name}}</view>
        <view class="fund-meta">{{item.code}} · {{item.sector}}</view>
      </view>
      <view class="{{item.change >= 0 ? 'fund-change rise' : 'fund-change fall'}}">
        {{item.changeText}}
      </view>
    </view>

    <view class="empty" wx:if="{{!funds.length}}">
      <view class="empty-title">暂无排名数据</view>
      <view class="empty-desc">切换全市场或从世界网络重新选择板块</view>
    </view>
  </scroll-view>
</view>
